# SANAD local demo defaults
SANAD_DATABASE_URL=sqlite:///./sanad.db
SANAD_STORAGE_ROOT=./storage

SANAD_ACTIVE_PROVIDER=tmt_api

# Official TMT API (Google TMT Hackathon 2026)
# When set, provider uses the official /lang-translate endpoint first.
# When missing, it falls back to legacy/fixture automatically.
SANAD_TMT_API_KEY=
SANAD_TMT_OFFICIAL_ENDPOINT=https://tmt.ilprl.ku.edu.np/lang-translate
SANAD_TMT_TIMEOUT_SECONDS=20
SANAD_TMT_PROVIDER_BATCH_SIZE=25
SANAD_TMT_ENABLE_FALLBACK=true
SANAD_TMT_RATE_LIMIT_DELAY=0.25

# Legacy public TMT endpoint (auto-used as Tier 2 fallback)
SANAD_TMT_API_ENDPOINT=https://tmt.ilprl.ku.edu.np
SANAD_TMT_AUTH_METHOD=none
